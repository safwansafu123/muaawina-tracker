        totalPaid: membersObj[id].paid,
        balance: membersObj[id].balance,
        pendingList: membersObj[id].pending,
        loginCount: logInfo.count,     // പുതിയത്
        lastLogin: lastLogStr          // പുതിയത്
      });
    }




    let approvals = [];
    if (qData && qData.length > 1) {
      for(let i = 1; i < qData.length; i++) {
        if(qData[i][6] === "Processing") {
          let reqId = String(qData[i][1]).trim();
          let dtObj = qData[i][0];
          let dateStr = (dtObj instanceof Date) ? Utilities.formatDate(dtObj, Session.getScriptTimeZone(), "dd MMM, hh:mm a") : "N/A";
         
          approvals.push({
            rowIdx: i + 1,
            date: dateStr,
            memberId: reqId,
            name: qData[i][2],
            batch: membersObj[reqId] ? membersObj[reqId].batch : '...',
            year: qData[i][4],
            month: qData[i][5]
          });
        }
      }
    }




    return { totalCollected: grandTotal, totalPending: grandPending, members: adminMembers, approvals: approvals, config: config };
  } catch(e) {
    return { error: "അഡ്മിൻ ഡാറ്റ ലഭ്യമാക്കുന്നതിൽ പിഴവ്: " + e.message };
  }
}




// ഒരാളുടെ അപേക്ഷ മാത്രം അപ്രൂവ് ചെയ്യാനുള്ള ഫംഗ്ഷൻ
function approvePayment(rowIdx, memberId, year, month) {
  try {
    const ss = getSS();
    const qSheet = ss.getSheetByName('Approval_Queue');
    if(!qSheet) return { error: "Approval_Queue sheet not found." };


    // 1. ക്യൂവിൽ ആ വ്യക്തിയുടെ അപേക്ഷ മാത്രം 'Approved' എന്ന് മാറ്റുന്നു
    qSheet.getRange(rowIdx, 7).setValue('Approved');


    // 2. ട്രാക്കിംഗ് ഷീറ്റിൽ ആ മാസത്തിൽ ടിക്ക് (TRUE) നൽകുന്നു
    const trackingSheets = ss.getSheets().filter(s => /^\d{4}$/.test(s.getName()) || s.getName().toLowerCase().includes('payment'));


    for(let sheet of trackingSheets) {
      let sName = sheet.getName();
      let checkYear = sName === 'Payment_Tracker' ? new Date().getFullYear().toString() : sName;


      if (checkYear !== String(year)) continue;


      const sheetData = sheet.getDataRange().getValues();
      if(sheetData.length < 1) continue;


      const rIdx = sheetData.findIndex(r => String(r[0]).trim() === String(memberId).trim());
      if(rIdx === -1) continue;


      const mStr = String(month).toLowerCase().substring(0, 3);
      const cIdx = sheetData[0].findIndex(c => String(c).trim().toLowerCase().startsWith(mStr));


      if(cIdx > -1) {
        sheet.getRange(rIdx + 1, cIdx + 1).setValue(true);
        break; // കണ്ടെത്തി അപ്ഡേറ്റ് ചെയ്താൽ പിന്നെ ലൂപ്പ് നിർത്തുന്നു
      }
    }
    return { success: true };
  } catch(e) {
    return { error: e.message };
  }
}




function rejectPayment(rowIdx) {
  const qSheet = getSS().getSheetByName('Approval_Queue');
  if(qSheet) qSheet.getRange(rowIdx, 7).setValue('Rejected');
  return { success: true };
}



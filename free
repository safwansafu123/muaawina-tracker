      let email = String(data[i][6]).trim(); // ഡാറ്റാബേസിലെ 7-ാമത്തെ കോളം (Email)
      let name = data[i][1];


      // ഫോൺ നമ്പർ കുടിശ്ശികക്കാരുടെ ലിസ്റ്റിൽ ഉണ്ടെന്നും ഇമെയിൽ ഉണ്ടെന്നും ഉറപ്പാക്കുന്നു
      if(phonesList.includes(phone) && email && email.includes('@')) {
        let subject = "MUAAWINA - വരിസംഖ്യ റിമൈൻഡർ";
        let body = `السلام عليكم ${name},\n\nനിങ്ങളുടെ MUAAWINA വരിസംഖ്യയിൽ ${monthStr} മാസത്തെ തുക അടക്കാൻ ബാക്കിയുണ്ട്. ദയവായി എത്രയും വേഗം അടക്കാൻ ശ്രദ്ധിക്കുക.\n\nനന്ദി,\nMUAAWINA Admin.`;
       
        // ഇമെയിൽ അയക്കുന്നു
        MailApp.sendEmail(email, subject, body);
        sentCount++;
      }
    }
   
    return { success: true, count: sentCount };
  } catch(e) {
    return { error: "ഇമെയിൽ അയക്കുന്നതിൽ പിഴവ്: " + e.message };
  }
}

// --- പുതിയ ആപ്പിന് ഡാറ്റ കൈമാറാനുള്ള API (പാലം) ---
function doPost(e) {
  var output = ContentService.createTextOutput();
  output.setMimeType(ContentService.MimeType.JSON);
  try {
    var req = JSON.parse(e.postData.contents);
    var action = req.action;
    var data = req.data || {};
    var result = {};

    if (action === 'checkPendingApprovals') { result = checkPendingApprovals(); }
    else if (action === 'getMemberData') { result = getMemberData(data.phone, data.mid); }
    else if (action === 'getAppSettings') { result = getAppSettings(); }
    else if (action === 'getAdminData') { result = getAdminData(); }
    else if (action === 'submitSinglePaymentRequest') { result = submitSinglePaymentRequest(data.id, data.name, data.phone, data.year, data.month); }
    else if (action === 'submitBulkPaymentRequest') { result = submitBulkPaymentRequest(data.id, data.name, data.phone, data.targetData); }
    else if (action === 'approvePayment') { result = approvePayment(data.r, data.id, data.y, data.m); }
    else if (action === 'rejectPayment') { result = rejectPayment(data.r); }
    else if (action === 'processAdminBulkAction') { result = processAdminBulkAction(data.type); }
    else if (action === 'sendDefaulterEmails') { result = sendDefaulterEmails(data.phones, data.monthStr); }
    else if (action === 'sendPushNotification') { result = sendPushNotification(data.title, data.message); }
    else { result = {error: "Unknown Action"}; }

    output.setContent(JSON.stringify(result));
  } catch(err) {
    output.setContent(JSON.stringify({error: "API Error: " + err.message}));
  }
  return output;
}

